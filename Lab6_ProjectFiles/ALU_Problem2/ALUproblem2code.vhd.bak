library ieee;
use ieee.std_logic_1164.all;
use ieee.std_logic_unsigned.all;
use ieee.numeric_std.all;

entity ALUcode is
    port ( Clock: in std_logic;              --clock input
           A,B: in unsigned (7 downto 0);    --8 bit input from latch A and B
           student_id: in unsigned (3 downto 0); --4 bit student id from FSM
           OP: in unsigned(15 downto 0);     --16-bit selector for Operation from Decoder
           neg: out std_logic;               --is the result negative? set -ve bit output
           R1: out unsigned(3 downto 0);     --lower 4-bits of 8-bit Results Output
           R2: out unsigned(3 downto 0) );   --higher 4-bits of 8-bits Results Output
end ALUcode;

architecture calculation of ALUcode is   --temp signal declaration
    signal Reg1,Reg2,Result: unsigned(7 downto 0):=(others=> '0');
    signal Reg4: unsigned(0 to 7);
begin
    Reg1 <= A;    --temp store A in Reg1
    Reg2 <= B;    --temp store B in Reg2

process(Clock,OP)
begin
    if(rising_edge(Clock)) THEN
	 
case OP is

--1
    WHEN "0000000000000001" =>
        Result(0) <= Reg1(2);
        Result(1) <= Reg1(3);
        Result(2) <= Reg1(4);
        Result(3) <= Reg1(5);
        Result(4) <= Reg1(6);
        Result(5) <= Reg1(7);
        Result(6) <= '1';
        Result(7) <= '1';
        neg <= '0';

--2
    WHEN "0000000000000010" => Result <= ((Reg1 - Reg2) + "0100");
        if (Reg2 > Reg1) then 
            neg <= '1';  --if second number higher then its negative
        else 
            neg <= '0';
        end if;

--3
    WHEN "0000000000000100" =>
        if (Reg1 > Reg2) then 
            Result <= Reg1;
        else 
            Result <= Reg2;
        end if;
        neg <= '0';

--4 --swap top 4 bits of A with lower 4 bits of B
    WHEN "0000000000001000" =>
        Result(0) <= Reg1(0);
        Result(1) <= Reg1(1);
        Result(2) <= Reg1(2);
        Result(3) <= Reg1(3);
        Result(4) <= Reg2(0);
        Result(5) <= Reg2(1);
        Result(6) <= Reg2(2);
        Result(7) <= Reg2(3);
        neg <= '0';

--5 --increase A by 1
    WHEN "0000000000010000" => 
        Result <= Reg1 + "00000001";
        neg <= '0';

--6 --and
    WHEN "0000000000100000" => 
        Result <= (Reg1 and Reg2);
        neg <= '0';

--7
    WHEN "0000000001000000" =>
        Result(0) <= Reg1(0);
        Result(1) <= Reg1(1);
        Result(2) <= Reg1(2);
        Result(3) <= Reg1(3);
        Result(4) <= not(Reg1(4));
        Result(5) <= not(Reg1(5));
        Result(6) <= not(Reg1(6));
        Result(7) <= not(Reg1(7));
        neg <= '0';

--8
    WHEN "0000000010000000" =>
        Result(0) <= Reg2(3);
        Result(1) <= Reg2(4);
        Result(2) <= Reg2(5);
        Result(3) <= Reg2(6);
        Result(4) <= Reg2(7);
        Result(5) <= Reg2(0);
        Result(6) <= Reg2(1);
        Result(7) <= Reg2(2);
        neg <= '0';

--9 --confirm
    WHEN "0000000100000000" => 
        Result <= "00000000";
        neg <= '0';

    WHEN OTHERS => 
        Result <= "00000000";
        neg <= '0';

end case;
end if;
end process;

R1  <= Result(3 downto 0); --since output 7-seg can only 4-bits
LR2 <= Result(7 downto 4); --split into two 4 bits

end calculation;
