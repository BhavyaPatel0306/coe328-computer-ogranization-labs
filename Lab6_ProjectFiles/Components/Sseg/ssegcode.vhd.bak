LIBRARY ieee;
USE ieee.std_logic_1164.all;

ENTITY ssegcode IS
    PORT ( bcd     : IN  STD_LOGIC_VECTOR(3 DOWNTO 0);
           neg     : IN  STD_LOGIC;
           leds    : OUT STD_LOGIC_VECTOR(0 TO 6);
           leds_neg: OUT STD_LOGIC_VECTOR(0 TO 6));
END ssegcode;

ARCHITECTURE Behavior OF ssegcode IS
BEGIN
    PROCESS (bcd, neg)
    BEGIN
        if neg = '1' then
            -- only turn on led g
            leds_neg <= "0000001";

            case bcd is                               -- abcdefg
                when "1111" => leds <= "0110000"; -- -1
                when "1110" => leds <= "1011011"; -- -2
                when "1101" => leds <= "1111001"; -- -3
                when "1100" => leds <= "0110011"; -- -4
                when "1011" => leds <= "0110111"; -- -5
                when "1010" => leds <= "0111111"; -- -6
                when "1001" => leds <= "1110000"; -- -7
                when "1000" => leds <= "1111111"; -- -8
                when others => leds <= "-------";
            end case;

        else
            leds_neg <= "0000000";  -- 0 is considered positive

            CASE bcd IS                                -- abcdefg
                WHEN "0000" => leds <= "1111110"; -- 0
                WHEN "0001" => leds <= "0110000"; -- 1
                WHEN "0010" => leds <= "1101101"; -- 2
                WHEN "0011" => leds <= "1111001"; -- 3
                WHEN "0100" => leds <= "0110011"; -- 4
                WHEN "0101" => leds <= "1011011"; -- 5
                WHEN "0110" => leds <= "1011111"; -- 6
                WHEN "0111" => leds <= "1110000"; -- 7
                WHEN "1000" => leds <= "1111111"; -- 8
                WHEN "1001" => leds <= "1111011"; -- 9
                WHEN "1010" => leds <= "1110111"; -- A
                WHEN "1011" => leds <= "0011111"; -- B
                WHEN "1100" => leds <= "1001110"; -- C
                WHEN "1101" => leds <= "0111101"; -- D
                WHEN "1110" => leds <= "1001111"; -- E
                WHEN "1111" => leds <= "1000111"; -- F
                WHEN OTHERS => leds <= "-------";
            END CASE;
        end if;
    END PROCESS;
END Behavior;
