LIBRARY ieee;
USE ieee.std_logic_1164.all;

ENTITY modifiedSseg IS
    PORT (
        bcd   : IN  STD_LOGIC_VECTOR(3 DOWNTO 0); 
        sign  : IN  STD_LOGIC;                   
        leds1 : OUT STD_LOGIC_VECTOR(1 TO 7);    -- segments for y/n
        leds2 : OUT STD_LOGIC_VECTOR(1 TO 7)     -- segments for sign
    );
END modifiedSseg;

ARCHITECTURE Behavior OF modifiedSseg IS
BEGIN
    PROCESS(bcd, sign)
    BEGIN
        -- sign display (second 7-seg)
        IF sign = '0' THEN
            leds2 <= NOT "0000000";   -- blank
        ELSE
            leds2 <= NOT "0000001";   -- minus sign (only segment g on, for example)
        END IF;

        -- y / n display (first 7-seg)
        IF bcd(0) = '1' THEN          -- odd
            leds1 <= NOT "0111011";   -- pattern for 'y'
        ELSE                          -- even
            leds1 <= NOT "0010101";   -- pattern for 'n'
        END IF;
    END PROCESS;
END Behavior;